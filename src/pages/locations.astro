---
import Layout from '../layouts/Layout.astro';

const communes = [
  "Anderlecht", "Bruxelles-Ville", "Ixelles", "Etterbeek", "Evere", 
  "Ganshoren", "Jette", "Koekelberg", "Auderghem", "Schaerbeek", 
  "Berchem-Sainte-Agathe", "Saint-Gilles", "Molenbeek-Saint-Jean", 
  "Saint-Josse-ten-Noode", "Woluwe-Saint-Lambert", "Woluwe-Saint-Pierre", 
  "Uccle", "Forest", "Watermael-Boitsfort"
];
---

<Layout title="Zones d'Intervention" description="Découvrez nos zones d'intervention à Bruxelles et ses alentours. Aqua Débouchage Service intervient dans les 19 communes de Bruxelles.">
  
  <div class="page-header">
    <div class="container text-center">
      <h1>Zones d'<span class="highlight">Intervention</span></h1>
      <p class="subtitle">Nous couvrons l'ensemble des 19 communes de Bruxelles avec un délai d'intervention ultra-rapide.</p>
    </div>
  </div>

  <section class="locations-section">
    <div class="container">
      <div class="locations-grid">
        <div class="locations-map">
          <div class="map-placeholder">
            <!-- Simulated map visual -->
            <div class="map-inner">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="map-icon"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"></polygon><line x1="9" y1="3" x2="9" y2="21"></line><line x1="15" y1="3" x2="15" y2="21"></line></svg>
              <h3>Région de Bruxelles-Capitale</h3>
            </div>
          </div>
        </div>
        
        <div class="locations-list-container">
          <h2>Les <span class="highlight">19 communes</span> desservies</h2>
          <p>Notre équipe de techniciens est répartie stratégiquement pour garantir une intervention en moins de 30 minutes partout à Bruxelles.</p>
          
          <ul class="communes-list">
            {communes.map((commune) => (
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                {commune}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="banner-section">
    <div class="container text-center">
      <h2>Vous êtes en périphérie bruxelloise ?</h2>
      <p>Nous intervenons également dans le Brabant Wallon et Flamand. Contactez-nous pour vérifier notre disponibilité dans votre commune.</p>
      <a href="/contact" class="btn btn-primary mt-4">Nous Contacter</a>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background-color: var(--color-background-alt);
    padding: 6rem 2rem 4rem;
  }

  .page-header h1 {
    font-size: 3rem;
    font-weight: 800;
  }

  .highlight {
    color: var(--color-primary);
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .map-placeholder {
    width: 100%;
    height: 500px;
    background: linear-gradient(135deg, rgba(0, 168, 255, 0.1) 0%, rgba(0, 68, 204, 0.1) 100%);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px dashed rgba(0, 168, 255, 0.3);
  }

  .map-inner {
    text-align: center;
    color: var(--color-primary);
  }

  .map-icon {
    width: 80px;
    height: 80px;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .locations-list-container h2 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .locations-list-container p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .communes-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .communes-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    color: var(--color-text);
  }

  .banner-section {
    background-color: var(--color-primary);
    color: white;
    padding: 4rem 2rem;
  }

  .banner-section h2 {
    color: white;
    margin-bottom: 1rem;
  }

  .banner-section p {
    font-size: 1.1rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
  }

  .mt-4 {
    margin-top: 2rem;
  }

  .btn-primary.mt-4 {
    background: white;
    color: var(--color-primary);
    box-shadow: none;
  }

  .btn-primary.mt-4:hover {
    background: var(--color-background-alt);
    transform: translateY(-2px);
  }

  @media (max-width: 992px) {
    .locations-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .map-placeholder {
      height: 350px;
    }
  }

  @media (max-width: 576px) {
    .communes-list {
      grid-template-columns: 1fr;
    }
  }
</style>
