---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Contactez Aqua Débouchage Service pour une urgence plomberie ou un devis gratuit à Bruxelles. Disponibles 24/7.">
  
  <div class="page-header">
    <div class="container text-center">
      <h1>Nous <span class="highlight">Contacter</span></h1>
      <p class="subtitle">Une urgence ? Un projet ? N'hésitez pas à nous contacter, notre équipe est à votre disposition.</p>
    </div>
  </div>

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        
        <div class="contact-info">
          <h2>Informations de <span class="highlight">Contact</span></h2>
          <p>Pour toute urgence, privilégiez l'appel téléphonique. Nous intervenons en moins de 30 minutes à Bruxelles.</p>
          
          <div class="info-items">
            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <div>
                <h3>Téléphone</h3>
                <p><a href="tel:+32000000000">+32 00 000 00 00</a></p>
                <span class="badge">Urgence 24/7</span>
              </div>
            </div>
            
            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <h3>Email</h3>
                <p><a href="mailto:contact@aquadebouchage.be">contact@aquadebouchage.be</a></p>
              </div>
            </div>
            
            <div class="info-item">
              <div class="info-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div>
                <h3>Zone d'Intervention</h3>
                <p>Bruxelles (19 communes)<br>Brabant Wallon & Flamand</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="contact-form-container">
          <h2>Demander un <span class="highlight">Devis</span></h2>
          <form class="contact-form">
            <div class="form-group">
              <label for="name">Nom / Société</label>
              <input type="text" id="name" name="name" required placeholder="Votre nom" />
            </div>
            
            <div class="form-group">
              <label for="phone">Téléphone</label>
              <input type="tel" id="phone" name="phone" required placeholder="Votre numéro de téléphone" />
            </div>
            
            <div class="form-group">
              <label for="message">Description du problème</label>
              <textarea id="message" name="message" rows="5" required placeholder="Décrivez brièvement votre problème ou votre projet..."></textarea>
            </div>
            
            <button type="button" class="btn btn-primary btn-submit">Envoyer la demande</button>
          </form>
        </div>
        
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header {
    background-color: var(--color-background-alt);
    padding: 6rem 2rem 4rem;
  }

  .page-header h1 {
    font-size: 3rem;
    font-weight: 800;
  }

  .highlight {
    color: var(--color-primary);
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .contact-info h2, .contact-form-container h2 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .contact-info p {
    color: var(--color-text-light);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .info-icon {
    width: 60px;
    height: 60px;
    background: rgba(0, 168, 255, 0.1);
    color: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-item h3 {
    font-size: 1.2rem;
    margin-bottom: 0.25rem;
  }

  .info-item p {
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .info-item a {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .info-item a:hover {
    color: var(--color-primary);
  }

  .badge {
    display: inline-block;
    padding: 0.2rem 0.8rem;
    background-color: #ff4757;
    color: white;
    border-radius: 50px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .contact-form-container {
    background: white;
    padding: 3rem;
    border-radius: 20px;
    box-shadow: 0 15px 40px rgba(0,0,0,0.05);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-group input, .form-group textarea {
    width: 100%;
    padding: 1rem;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 10px;
    font-family: inherit;
    font-size: 1rem;
    transition: all 0.3s ease;
    background: var(--color-background-alt);
  }

  .form-group input:focus, .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    background: white;
    box-shadow: 0 0 0 4px rgba(0, 68, 204, 0.1);
  }

  .btn-submit {
    width: 100%;
    font-size: 1.1rem;
    padding: 1.2rem;
  }

  @media (max-width: 992px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .contact-form-container {
      padding: 2rem;
    }
  }
</style>
